# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_VISION_MODEL=gpt-4o

# ElevenLabs
ELEVENLABS_API_KEY=

# Google Cloud Speech-to-Text service account.
# Either point this to the absolute path of your downloaded service account JSON,
# or leave it empty and place the file at config/speech_to_text_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=

# Serial port for the ESP32 motor controller (modules/motor_run.py)
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD_RATE=115200

# Optional overrides for asset paths (defaults live under assets/)
WAKEWORD_MODEL_PATH=
BEEP_SOUND_PATH=
ROBOT_SPEECH_PATH=
VOSK_MODEL_PATH=
